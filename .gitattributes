# =========================
# Normalize text files
# =========================
* text=auto eol=lf

# =========================
# Source Code
# =========================
*.cpp text
*.cc text
*.c text
*.h text
*.hpp text
*.py text
*.java text
*.js text
*.ts text
*.html text
*.css text
*.json text
*.xml text
*.yml text
*.yaml text
*.md text
*.txt text
*.cmake text

# =========================
# Scripts
# =========================
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

